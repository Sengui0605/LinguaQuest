// Reglas para LinguaQuest: teacher_licenses, active_codes, students, assignments, quizzes
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Licencias: lectura y actualización (para el estado general de licencias)
    match /teacher_licenses/{licenseKey} {
      allow read: if true;
      allow update: if true;
      allow create: if false;
      allow delete: if false;
    }
    
    // Códigos de clase: lectura y creación, borrado (al generar nuevos) 
    match /active_codes/{code} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
      allow update: if false;
    }
    
    // Estudiantes: creación, lectura, actualización. No eliminar.
    match /students/{studentId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    
    // Tareas: lectura, creación y borrado (por el profe)
    match /assignments/{assignmentId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
      allow update: if false;
    }

    // Quizzes (QuizBuilder): lectura, creación, actualización y borrado
    match /custom_quizzes/{quizId} {
      allow read, create, update, delete: if true;
    }
  }
}
