{
  "name": "linguaquest",
  "version": "1.0.0",
  "description": "LinguaQuest - Educational English Learning Game inspired by Duolingo",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "serve": "npx http-server . -p 8080 -o",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux AppImage deb",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.linguaquest.app",
    "productName": "LinguaQuest",
    "directories": {
      "output": "dist"
    },
    "files": [
      "public/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons/icon.png",
      "category": "Education"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icons/icon.png",
      "category": "public.app-category.education"
    }
  },
  "keywords": [
    "education",
    "english",
    "learning",
    "quiz",
    "game"
  ],
  "author": "LinguaQuest Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0"
  }
}
